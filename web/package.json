{
  "name": "syncpad-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "e2e": "npm run build && playwright test",
    "stress": "esbuild ../scripts/stress.ts --bundle --platform=node --format=cjs --outfile=node_modules/.cache/syncpad-stress.cjs && node node_modules/.cache/syncpad-stress.cjs",
    "gen:assets": "node scripts/gen-assets.mjs"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "html-to-image": "^1.11.13",
    "monaco-editor": "^0.52.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0",
    "ws": "^8.21.0"
  }
}
